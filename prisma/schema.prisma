generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Interne Benutzer (Admin- / Benutzerbereich)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  USER
}

/// Kunden (Kundenbereich, optional mit Logindaten)
model Customer {
  id             String   @id @default(cuid())
  customerNumber String   @unique
  companyName    String
  contactName    String?
  email          String?  @unique
  passwordHash   String? // gesetzt = Kunde kann sich einloggen
  // Adresse
  street         String?
  zip            String?
  city           String?
  country        String   @default("DE")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  discounts CustomerDiscount[]
  orders    Order[]
}

/// Rabattgruppen
model DiscountGroup {
  code       String   @id @db.VarChar(10) // Rabattgruppen-Code (1–10 Zeichen)
  name       String?
  percent    Decimal? @db.Decimal(5, 2) // kann leer sein
  individual Boolean  @default(false) // Individuell J/N
  minMargin  Decimal? @db.Decimal(5, 2) // Mindestmarge %
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  articles          Article[]
  customerDiscounts CustomerDiscount[]
}

/// Artikel
model Article {
  id               String   @id @default(cuid())
  partNumber       String   @unique // Teilenummer
  partNumberFmt    String // Teilenummer formatiert
  titleDe          String
  titleEn          String
  listPrice        Decimal  @db.Decimal(12, 2) // Listenpreis
  discountGroupCode String?  @db.VarChar(10)
  weight           Int? // Gewicht in Gramm
  length           Int? // Länge in mm
  width            Int? // Breite in mm
  height           Int? // Höhe in mm
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  discountGroup DiscountGroup? @relation(fields: [discountGroupCode], references: [code], onDelete: SetNull, onUpdate: Cascade)
  orderItems    OrderItem[]

  @@index([discountGroupCode])
}

/// Kundenrabatte (gruppiert nach Kunde)
model CustomerDiscount {
  id                String   @id @default(cuid())
  customerId        String
  discountGroupCode String   @db.VarChar(10)
  discount          Decimal? @db.Decimal(5, 2) // Rabatt %
  individual        Boolean  @default(false) // Individuell J/N
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  discountGroup DiscountGroup @relation(fields: [discountGroupCode], references: [code], onDelete: Cascade, onUpdate: Cascade)

  @@unique([customerId, discountGroupCode])
  @@index([customerId])
}

/// Bestellungen
model Order {
  id             String         @id @default(cuid())
  orderNumber    Int            @unique @default(autoincrement())
  customerId          String
  note                String?
  mercedesOrderNumber String? // Mercedes Bestellnummer
  createdBy           String? // Name des anlegenden Benutzers
  status         OrderStatus    @default(open) // Bestellstatus
  deliveryStatus DeliveryStatus @default(open) // Lieferstatus
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  deliveryNotes DeliveryNote[]
  invoices      Invoice[]

  @@index([customerId])
}

/// Bestellstatus (englisch gespeichert)
enum OrderStatus {
  open // offen
  ordered // bestellt
}

/// Lieferstatus (englisch gespeichert)
enum DeliveryStatus {
  open // offen
  partially_delivered // teilweise geliefert
  fully_delivered // vollständig geliefert
}

/// Positions-Status (englisch gespeichert)
enum OrderItemStatus {
  open // offen
  needs_inquiry // muss angefragt werden
  inquired // angefragt
  ordered // bestellt
  delivered // geliefert
}

/// Bestellpositionen
model OrderItem {
  id                    String          @id @default(cuid())
  orderId               String
  position              Int // Positionsnummer (Sortierung)
  quantity              Int             @default(1) // Anzahl
  partNumber            String // Teilenummer (angefragt)
  partNumberReplacement String? // Teilenummer Ersatz (später)
  articleId             String? // verknüpfter Artikel (falls gefunden)
  priceCustomerStandard Decimal?        @db.Decimal(12, 2) // preis_kunde_standard
  priceRequested        Decimal?        @db.Decimal(12, 2) // preis_angefragt
  priceBilling          Decimal?        @db.Decimal(12, 2) // preis_abrechnung
  qtyReceived           Int? // Anz. Wareneingang
  qtyDelivered          Int? // Anz. Lieferung
  qtyBilled             Int? // Anz. Abgerechnet
  status                OrderItemStatus @default(open)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  article           Article?           @relation(fields: [articleId], references: [id], onDelete: SetNull)
  deliveryNoteItems DeliveryNoteItem[]
  invoiceItems      InvoiceItem[]

  @@index([orderId])
  @@index([articleId])
}

/// Anwendungseinstellungen (Key-Value, z. B. easybill API-Key)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum DeliveryType {
  shipping // Versand
  pickup // Abholung
}

enum DeliveryNoteStatus {
  open // offen
  shipped // versendet
  picked_up // abgeholt
}

/// Lieferscheine
model DeliveryNote {
  id        String             @id @default(cuid())
  number    Int                @unique @default(autoincrement())
  orderId   String
  type      DeliveryType       @default(shipping)
  status    DeliveryNoteStatus @default(open)
  createdBy String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  order Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items DeliveryNoteItem[]

  @@index([orderId])
}

model DeliveryNoteItem {
  id             String @id @default(cuid())
  deliveryNoteId String
  orderItemId    String
  quantity       Int

  deliveryNote DeliveryNote  @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  orderItem    OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@index([deliveryNoteId])
  @@index([orderItemId])
}

enum InvoiceStatus {
  open // offen
  sent // versendet
  paid // bezahlt
}

/// Rechnungen
model Invoice {
  id         String        @id @default(cuid())
  number     Int           @unique @default(autoincrement())
  orderId    String
  status     InvoiceStatus @default(open)
  easybillId String? // interne easybill-Dokument-ID
  createdBy  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  order Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items InvoiceItem[]

  @@index([orderId])
}

model InvoiceItem {
  id                 String   @id @default(cuid())
  invoiceId          String
  orderItemId        String
  deliveryNoteItemId String?
  quantity           Int
  unitPrice          Decimal  @db.Decimal(12, 2) // Abrechnungspreis pro Einheit

  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItem        OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  deliveryNoteItem DeliveryNoteItem? @relation(fields: [deliveryNoteItemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([orderItemId])
}
